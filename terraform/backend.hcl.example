# Copy to backend.hcl (gitignored) and run:
#   terraform init -backend-config=backend.hcl
#
# The DynamoDB table needs a partition key named "LockID" (String) - the name
# Terraform's S3 backend hardcodes and expects to already exist.

bucket         = "ads-statefile-store"
key            = "ads/terraform.tfstate"
region         = "ap-southeast-1"
dynamodb_table = "ads-state-lock-table"
encrypt        = true
